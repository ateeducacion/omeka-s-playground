{
  "name": "omeka-s-playground",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-runtime": "node ./scripts/prepare-runtime.mjs",
    "sync-browser-deps": "node ./scripts/sync-browser-deps.mjs",
    "build-worker": "node ./scripts/esbuild.worker.mjs",
    "bundle": "./scripts/build-omeka-bundle.sh",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@php-wasm/fs-journal": "^3.1.46",
    "@php-wasm/stream-compression": "^3.1.46",
    "@php-wasm/universal": "^3.1.46",
    "@php-wasm/web": "^3.1.46",
    "fflate": "^0.8.3",
    "zstddec": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1"
  },
  "overrides": {
    "@php-wasm/universal": "$@php-wasm/universal",
    "@php-wasm/web": "$@php-wasm/web"
  }
}
