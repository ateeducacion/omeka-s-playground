{
  "bundleVersion": "0.1.0",
  "defaultBlueprintUrl": "./assets/blueprints/default.blueprint.json",
  "addonProxyPath": "/__addon_proxy__",
  "addonProxyUrl": "https://zip-proxy.erseco.workers.dev/",
  "outboundHttp": {
    "enabled": true,
    "allowedHosts": [
      "localhost",
      "127.0.0.1",
      "omeka.org",
      "api.github.com",
      "raw.githubusercontent.com",
      "github.com",
      "codeload.github.com",
      "objects.githubusercontent.com",
      "data.jsdelivr.com",
      "cdn.jsdelivr.net",
      "zip-proxy.erseco.workers.dev"
    ],
    "allowedMethods": [
      "GET",
      "HEAD"
    ],
    "proxyAllCrossOrigin": true,
    "timeoutMs": 30000,
    "maxBytes": 52428800,
    "probeUrl": "https://omeka.org/add-ons/json/s_module.json"
  },
  "siteTitle": "Omeka S Playground",
  "landingPath": "/admin",
  "locale": "en_US",
  "timezone": "UTC",
  "autologin": true,
  "resetOnVersionMismatch": true,
  "admin": {
    "username": "admin",
    "password": "password",
    "email": "admin@example.com"
  },
  "omekaVersion": "4.2.0",
  "runtimes": [
    {
      "id": "php81",
      "label": "PHP 8.1",
      "phpVersion": "8.1",
      "default": false
    },
    {
      "id": "php82",
      "label": "PHP 8.2",
      "phpVersion": "8.2",
      "default": false
    },
    {
      "id": "php83",
      "label": "PHP 8.3",
      "phpVersion": "8.3",
      "default": true
    },
    {
      "id": "php84",
      "label": "PHP 8.4",
      "phpVersion": "8.4",
      "default": false
    },
    {
      "id": "php85",
      "label": "PHP 8.5",
      "phpVersion": "8.5",
      "default": false
    }
  ]
}
